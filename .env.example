# -----------------------------
# App
# -----------------------------
NODE_ENV=development
PORT=4000

# -----------------------------
# Database
# -----------------------------
DATABASE_URL=postgres://username:password@localhost:5432/task_tracks

# -----------------------------
# Message encryption at rest
# Key values must decode to exactly 32 bytes.
# Supported formats:
#   base64:<base64-encoded-32-byte-key>
#   hex:<64-hex-char-key>
#   (raw 32-byte UTF-8 string also works)
#
# Single-key mode (backward compatible):
# MESSAGE_ENCRYPTION_KEY=base64:REPLACE_WITH_32_BYTE_BASE64_KEY
# MESSAGE_ENCRYPTION_KEY_ID=v1
#
# Rotation-ready multi-key mode:
# MESSAGE_ENCRYPTION_KEYS=v1=base64:OLD_KEY_BASE64,v2=base64:NEW_KEY_BASE64
# MESSAGE_ENCRYPTION_KEY_ID=v2
#
# Rotation sequence:
# 1) Add new key to MESSAGE_ENCRYPTION_KEYS and keep old key(s) listed
# 2) Set MESSAGE_ENCRYPTION_KEY_ID to the new key id
# 3) Restart server (new writes use new key id)
# 4) Keep old key(s) available until old ciphertext is re-encrypted
# -----------------------------
MESSAGE_ENCRYPTION_KEY=base64:REPLACE_WITH_32_BYTE_BASE64_KEY
MESSAGE_ENCRYPTION_KEY_ID=v1